PORT=5000
NODE_ENV=development
OPENAI_API_KEY=
# fixed | ai | hybrid
SIMULATION_QUERY_MODE=fixed

# Shopify Admin API (optional — required for /api/v1/shopify/*)
# Store hostname only, e.g. your-store.myshopify.com (https optional)
SHOPIFY_STORE_URL=
# Admin API access token (Custom App or private app)
SHOPIFY_ACCESS_TOKEN=
